                              <TechnicianCard orderTechs={selectedOrder.technicians} allTechs={technicians} isDarkMode={true} />
                          </div>

                          <ImageGalleryBlock title="原始規劃圖面" Icon={ImageIcon} images={selectedOrder.planningImages} onImageClick={setViewingImage} delayClass="delay-800 mt-4" />
                      </div>
                  )}
                </ErrorBoundary>
                <CompanyFooter darkMode={true} logo={companyBranding.logo} />
           </div>
        </div>
      );
  }

  // 2. Login
  if (view === 'login') return (
    <div className="min-h-screen bg-gray-50 flex flex-col items-center justify-center p-4">
        <DialogModal config={modalConfig} onClose={()=>setModalConfig(null)} />
