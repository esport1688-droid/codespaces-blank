const CalendarView = memo(({ orders, onSelectOrder, setViewDateCb, viewDate }) => {
    const today = new Date();
    
    const getDaysInMonth = (date) => new Date(date.getFullYear(), date.getMonth() + 1, 0).getDate();
    const getFirstDayOfMonth = (date) => new Date(date.getFullYear(), date.getMonth(), 1).getDay();
    const isSameDay = (d1, d2) => d1.getFullYear() === d2.getFullYear() && d1.getMonth() === d2.getMonth() && d1.getDate() === d2.getDate();

    const daysInMonth = getDaysInMonth(viewDate);
    const startDay = getFirstDayOfMonth(viewDate);
    
    const days = [];
    for (let i = 0; i < startDay; i++) days.push(null);
    for (let i = 1; i <= daysInMonth; i++) days.push(new Date(viewDate.getFullYear(), viewDate.getMonth(), i));

    const getDailyOrders = (date) => {
        if (!date) return [];
        return orders.filter(o => {
            if (!o.date) return false;
            const oDate = new Date(o.date);
            return isSameDay(oDate, date);
        }).sort((a,b) => (a.time || "00:00").localeCompare(b.time || "00:00"));
    };

    const calculateDailyLoad = (dailyOrders) => {
        let totalHours = 0;
        dailyOrders.forEach(o => {
            const duration = SERVICE_DURATIONS[o.serviceType] || 2;
            totalHours += duration;
        });
        return Math.min(100, (totalHours / 8) * 100); 
    };

    const [selectedDate, setSelectedDate] = useState(today);

    return (
        <div className="bg-white rounded-3xl shadow-xl border border-slate-100 max-w-2xl mx-auto mb-20 overflow-hidden">
            <div className="bg-slate-50 p-4 border-b border-slate-100 flex justify-between items-center">
                <button onClick={() => setViewDateCb(new Date(viewDate.getFullYear(), viewDate.getMonth() - 1, 1))} className="p-2 bg-white text-slate-500 rounded-xl shadow-sm hover:text-blue-600 transition"><ChevronLeft size={20}/></button>
                <div className="text-center">
                    <h2 className="text-lg font-bold text-slate-800">{viewDate.getFullYear()}年 {viewDate.getMonth() + 1}月</h2>
                    <p className="text-xs text-slate-400 font-medium tracking-wide">SCHEDULE OVERVIEW</p>
                </div>
                <button onClick={() => setViewDateCb(new Date(viewDate.getFullYear(), viewDate.getMonth() + 1, 1))} className="p-2 bg-white text-slate-500 rounded-xl shadow-sm hover:text-blue-600 transition"><ChevronRight size={20}/></button>
            </div>
            
            <div className="p-4">
                <div className="grid grid-cols-7 text-center mb-3">
                    {['日', '一', '二', '三', '四', '五', '六'].map((d, i) => (
                        <div key={d} className={`text-xs font-bold ${i === 0 || i === 6 ? 'text-orange-400' : 'text-slate-400'}`}>{d}</div>
                    ))}
                </div>
                
                <div className="grid grid-cols-7 gap-2 mb-6">
                    {days.map((day, idx) => {
                        const isToday = day && isSameDay(day, today);
                        const isSelected = day && isSameDay(day, selectedDate);
                        const dailyOrders = getDailyOrders(day);
                        const hasSurvey = dailyOrders.some(o => o.serviceType.includes('場勘'));
                        const hasInstall = dailyOrders.some(o => o.serviceType.includes('安裝') || o.status.includes('施工'));
                        const load = calculateDailyLoad(dailyOrders);
                        
                        return (
                            <div key={idx} onClick={() => day && setSelectedDate(day)} 
                                 className={`aspect-[4/5] rounded-2xl flex flex-col items-center pt-2 cursor-pointer transition-all relative border 
                                 ${!day ? 'invisible' : ''}
                                 ${isSelected 
                                    ? 'border-blue-500 bg-blue-50 ring-2 ring-blue-200 ring-offset-2 z-10 scale-105 shadow-md' 
                                    : (isToday ? 'bg-slate-800 text-white border-slate-700 shadow-md' : 'bg-white border-slate-100 hover:border-blue-300 hover:shadow-sm')}
                                 `}>
