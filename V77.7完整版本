const PaymentProgressBar = memo(({ total, paid }) => {
    const parseVal = (v) => { if (typeof v === 'number') return v; if (typeof v === 'string') return parseInt(v.replace(/,/g, '')) || 0; return 0; };
    const safeTotal = parseVal(total); const safePaid = parseVal(paid);
    if (!safeTotal) return null;
    const percentage = Math.min(100, Math.max(0, (safePaid / safeTotal) * 100));
    let colorClass = percentage >= 100 ? 'bg-green-500' : (percentage === 0 ? 'bg-gray-300' : 'bg-yellow-400');
    let statusText = percentage >= 100 ? '已結清' : (percentage === 0 ? '未付款' : '部分付款');
    return (
        <div className="mt-2">
            <div className="flex justify-between text-xs mb-1"><span className="text-gray-500 font-medium">收款進度</span><span className={`font-bold ${percentage >= 100 ? 'text-green-600' : 'text-orange-500'}`}>{statusText} ({Math.round(percentage)}%)</span></div>
            <div className="w-full bg-gray-100 rounded-full h-2 overflow-hidden"><div className={`h-2 rounded-full ${colorClass} transition-all duration-500`} style={{ width: `${percentage}%` }}></div></div>
            {safeTotal > safePaid && <div className="text-right mt-1"><span className="text-[10px] text-red-400">未收餘額: ${new Intl.NumberFormat('zh-TW').format(safeTotal - safePaid)}</span></div>}
        </div>
    );
});

