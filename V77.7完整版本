                {stats.installRegionalStats.length > 0 ? (
                    <div className="grid grid-cols-1 gap-6">
                        {stats.installRegionalStats.map((regionGroup, idx) => (
                            <div key={regionGroup.region} className="border border-purple-50 rounded-xl p-4 bg-purple-50/20">
                                <div className="flex justify-between items-center mb-3">
                                    <h3 className="font-bold text-gray-700 flex items-center gap-2">
                                        <span className={`w-2 h-2 rounded-full ${['bg-purple-500','bg-blue-500','bg-indigo-500','bg-violet-500','bg-sky-500'][idx%5]}`}></span>
                                        {regionGroup.region} <span className="text-xs text-gray-400 font-normal">({regionGroup.total} 案)</span>
                                    </h3>
                                </div>
                                <div className="space-y-3">
                                    {regionGroup.cityData.map((city) => (
                                        <div key={city.name} className="flex items-center gap-3">
                                            <span className="text-xs font-bold text-gray-600 w-16">{city.name}</span>
                                            <div className="flex-1 h-3 bg-gray-200 rounded-full overflow-hidden relative">
                                                <div 
                                                    className={`h-full rounded-full transition-all duration-1000 ${['bg-purple-500','bg-blue-500','bg-indigo-500','bg-violet-500','bg-sky-500'][idx%5]}`} 
                                                    style={{ width: `${Math.min(100, (city.count / regionGroup.total) * 100)}%` }}
                                                ></div>
                                            </div>
                                            <span className="text-xs font-bold text-gray-700 w-8 text-right">{city.count}</span>
                                        </div>
                                    ))}
                                </div>
                            </div>
                        ))}
                    </div>
                ) : (
                    <div className="text-center py-8 text-gray-400 text-sm">目前沒有待安裝案件</div>
                )}
            </div>

            <div className="bg-white rounded-2xl p-6 shadow-sm border border-gray-100"><div className="flex items-center gap-2 mb-4 pb-4 border-b border-gray-100"><DollarSign className="text-green-600" /><h2 className="text-lg font-bold text-gray-800">業績財務概況</h2></div><div className="grid grid-cols-2 gap-6 divide-x divide-gray-100"><div><p className="text-xs text-gray-400 mb-1">已確認營收 (成交)</p><div className="text-2xl font-bold text-green-600">{new Intl.NumberFormat('zh-TW', { style: 'currency', currency: 'TWD', maximumFractionDigits: 0 }).format(stats.totalSalesRevenue)}</div></div><div className="pl-6"><p className="text-xs text-gray-400 mb-1">預估潛在金額 (報價中)</p><div className="text-2xl font-bold text-gray-400">{new Intl.NumberFormat('zh-TW', { style: 'currency', currency: 'TWD', maximumFractionDigits: 0 }).format(stats.totalPotentialRevenue)}</div></div></div></div>
            <div className="bg-gradient-to-br from-green-500 to-green-700 rounded-2xl p-6 text-white shadow-lg"><div className="flex items-center gap-3 mb-2"><div className="p-2 bg-white/20 rounded-lg"><CheckCircle size={24} /></div><span className="text-green-100 font-medium">本月完工 PW 總數</span></div><div className="text-5xl font-bold mt-2">{stats.totalDealPW} <span className="text-xl font-normal text-green-200">顆</span></div></div>
            <div className="bg-white rounded-2xl p-6 shadow-sm border border-gray-100"><div className="flex items-center gap-2 mb-6 pb-4 border-b border-gray-100"><Briefcase className="text-blue-600" /><h2 className="text-lg font-bold text-gray-800">業務績效排行</h2></div><div className="space-y-6">{stats.sortedSales.map((sale) => (<div key={sale.name}><div className="flex justify-between text-sm mb-1"><span className="font-bold text-gray-800">{sale.name}</span><div className="text-right"><span className="font-bold text-green-600">{new Intl.NumberFormat('zh-TW', { style: 'currency', currency: 'TWD', maximumFractionDigits: 0 }).format(sale.revenue)}</span>{sale.potential > 0 && (<span className="text-xs text-gray-400 block">+ {new Intl.NumberFormat('zh-TW', { style: 'currency', currency: 'TWD', maximumFractionDigits: 0 }).format(sale.potential)} (預估)</span>)}</div></div><div className="w-full bg-gray-100 rounded-full h-2.5 flex overflow-hidden"><div className="h-2.5 bg-green-500" style={{ width: `${Math.max(0, (sale.revenue / stats.maxSalesRevenue) * 100)}%` }} title="已成交"></div><div className="h-2.5 bg-gray-300" style={{ width: `${Math.max(0, (sale.potential / stats.maxSalesRevenue) * 100)}%` }} title="預估中"></div></div></div>))}</div></div>
            <div className="bg-white rounded-2xl p-6 shadow-sm border border-gray-100"><div className="flex items-center gap-2 mb-6 pb-4 border-b border-gray-100"><Star className="text-yellow-500" /><h2 className="text-lg font-bold text-gray-800">KOL 導購績效</h2></div><div className="space-y-4">{stats.sortedKols.length > 0 ? stats.sortedKols.map((kol) => (<div key={kol.name} className="mb-4"><div className="flex justify-between text-sm mb-2"><span className="font-bold text-gray-800">{kol.name}</span><div className="text-right"><span className="font-bold text-yellow-600">{new Intl.NumberFormat('zh-TW', { style: 'currency', currency: 'TWD', maximumFractionDigits: 0 }).format(kol.revenue)}</span><span className="text-xs text-gray-500 block">PW 數量: {kol.pwCount}</span></div></div><div className="w-full bg-gray-100 rounded-full h-2"><div className="h-2 rounded-full bg-yellow-400" style={{ width: `${Math.max(5, (kol.revenue / stats.maxKolRevenue) * 100)}%` }}></div></div></div>)) : <p className="text-center text-gray-400 text-sm py-4">本月尚無 KOL 介紹案件</p>}</div></div>
            <div className="bg-white rounded-2xl p-6 shadow-sm border border-gray-100"><div className="flex items-center gap-2 mb-6 pb-4 border-b border-gray-100"><TrendingUp className="text-orange-500" /><h2 className="text-lg font-bold text-gray-800">技師績效 (場勘/安裝 PW)</h2></div><div className="space-y-4">{stats.sortedTechStats.map((tech) => (<div key={tech.name} className="mb-4"><div className="flex justify-between text-sm mb-2"><span className="font-bold text-gray-800">{tech.name}</span><span className="text-xs text-gray-500">成交: {tech.dealPW} 顆</span></div><div className="flex items-center gap-2 mb-1"><span className="text-xs w-8 text-gray-400">場勘</span><div className="flex-1 bg-gray-100 rounded-full h-2"><div className="h-2 rounded-full bg-blue-400" style={{ width: `${Math.max(5, (tech.surveyPW / stats.maxTechPW) * 100)}%` }}></div></div><span className="text-xs w-6 text-right">{tech.surveyPW}</span></div><div className="flex items-center gap-2"><span className="text-xs w-8 text-gray-400">安裝</span><div className="flex-1 bg-gray-100 rounded-full h-2"><div className="h-2 rounded-full bg-green-400" style={{ width: `${Math.max(5, (tech.installPW / stats.maxTechPW) * 100)}%` }}></div></div><span className="text-xs w-6 text-right">{tech.installPW}</span></div></div>))}</div></div>
        </main>
    </div>
  );

  // 7. Calendar
  if (view === 'calendar') {
     return (
        <div className="min-h-screen bg-gray-50 pb-20 font-sans text-gray-900">
            <header className="bg-white px-6 py-5 shadow-sm sticky top-0 z-10 flex justify-between items-center max-w-2xl mx-auto">
                <h1 className="text-xl font-bold flex items-center gap-2"><Calendar/> 智慧排程</h1>
                <div className="flex gap-2">
                    <button onClick={handleLogout} className="bg-red-50 text-red-500 p-2 rounded-full hover:bg-red-100" title="登出"><LogOut size={24} /></button>
                    <button onClick={() => setView('list')} className="bg-gray-100 text-gray-600 p-2 rounded-full hover:bg-gray-200"><X size={24} /></button>
                </div>
            </header>
            <main className="max-w-2xl mx-auto p-4 space-y-6">
                <CalendarView 
                    orders={orders} 
                    viewDate={calendarViewDate}
                    setViewDateCb={setCalendarViewDate}
                    onSelectOrder={(o) => startEdit(o)} 
                />
            </main>
        </div>
     );
  }

  // Default: List View
  return (
    <div className="min-h-screen bg-gray-50 pb-20 font-sans text-gray-900">
        <DialogModal config={modalConfig} onClose={()=>setModalConfig(null)} />
        {showSuccess && <Toast message={toastMsg} onClose={()=>setShowSuccess(false)} />}
        
        <header className="bg-white px-6 py-5 shadow-sm sticky top-0 z-10 max-w-2xl mx-auto w-full">
            <div className="flex justify-between items-center mb-4">
                <div><h1 className="text-xl font-bold">派案管理</h1><p className="text-xs text-gray-500 flex items-center gap-1">{useLegacyPath ? <span className="text-red-500">⚠️ 舊版資料模式</span> : <span className="text-green-500">✅ 安全資料模式</span>}</p></div>
                <div className="flex gap-2">
                    <button onClick={() => setView('calendar')} className="bg-white border border-gray-200 text-gray-600 p-2 rounded-full shadow-sm hover:bg-gray-50" title="行事曆"><Calendar size={24} /></button>
                    <button onClick={() => setView('system-settings')} className="bg-white border border-gray-200 text-gray-600 p-2 rounded-full shadow-sm hover:bg-gray-50" title="系統設定"><Settings size={24} /></button>
                    <button onClick={() => setView('manage-team')} className="bg-white border border-gray-200 text-gray-600 p-2 rounded-full shadow-sm hover:bg-gray-50" title="團隊管理"><UserCog size={24} /></button>
                    <button onClick={() => setView('stats')} className="bg-white border border-gray-200 text-gray-600 p-2 rounded-full shadow-sm hover:bg-gray-50" title="數據統計"><BarChart2 size={24} /></button>
                    <button onClick={handleLogout} className="bg-red-50 text-red-500 p-2 rounded-full hover:bg-red-100" title="登出"><LogOut size={24} /></button>
                    <button onClick={() => { setIsEditing(false); resetForm(); setView('create'); }} className="bg-blue-600 text-white p-2 rounded-full shadow-md hover:bg-blue-700"><Plus size={24} /></button>
                    <button onClick={reloadData} className="bg-gray-100 text-gray-600 p-2 rounded-full shadow-sm hover:bg-gray-200" title="重新整理資料"><RefreshCw size={24} /></button>
                </div>
            </div>
             
            <div className="mb-4 relative flex gap-2">
                <div className="relative flex-1">
                    <div className="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><Search size={18} className="text-gray-400" /></div>
                    <input type="text" className="block w-full pl-10 p-3 bg-gray-50 border border-gray-200 rounded-xl text-sm outline-none" placeholder="搜尋..." value={searchQuery} onChange={(e) => setSearchQuery(e.target.value)} />
                </div>
                <div className="relative">
                    <select 
                        value={sortType}
                        onChange={(e) => setSortType(e.target.value)}
                        className="h-full pl-9 pr-4 bg-white border border-gray-200 rounded-xl text-sm outline-none appearance-none font-bold text-gray-600 cursor-pointer hover:bg-gray-50"
                    >
                        <option value="date_desc">📅 預約日期 (新→舊)</option>
                        <option value="date_asc">📅 預約日期 (舊→新)</option>
                        <option value="created_desc">🕒 建立日期 (新→舊)</option>
                    </select>
                    <div className="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400 pointer-events-none">
                        <ArrowUpDown size={16}/>
                    </div>
                </div>
            </div>
            
            <div className="grid grid-cols-4 gap-2 mb-2">
                 <DashboardCard title="待場勘" count={dashboardCounts.surveyPending} color="#EF4444" icon={MapPin} onClick={() => setFilterStatus('survey_pending')} isActive={filterStatus === 'survey_pending'} />
                 <DashboardCard title="已報價" count={dashboardCounts.quoteDone} color="#3B82F6" icon={FileText} onClick={() => setFilterStatus('quote_done')} isActive={filterStatus === 'quote_done'} />
                 <DashboardCard title="待安裝" count={dashboardCounts.installPending} color="#8B5CF6" icon={Wrench} onClick={() => setFilterStatus('install_pending')} isActive={filterStatus === 'install_pending'} />
                 <DashboardCard title="已完工" count={dashboardCounts.installDone} color="#10B981" icon={CheckCircle} onClick={() => setFilterStatus('install_done')} isActive={filterStatus === 'install_done'} />
            </div>
            <button onClick={() => setFilterStatus('all')} className={`w-full py-2 rounded-lg text-sm font-bold mb-4 transition ${filterStatus === 'all' ? 'bg-gray-800 text-white' : 'bg-gray-100 text-gray-500'}`}>顯示全部</button>
        </header>

        <main className="max-w-2xl mx-auto p-4 space-y-4">
          <ErrorBoundary>
          {filteredOrders.map((order) => (
              <OrderCard 
                  key={order.id} 
                  order={order} 
                  onDelete={handleDeleteOrder} 
                  onEdit={startEdit}
                  onPreview={(o, completed) => { setSelectedOrder(o); setClientMode(completed ? 'warranty' : 'standard'); setView('client-view'); setViewingImage(null); }}
                  onShareLine={shareViaLine}
                  onCopy={copyContent}
                  onShareSMS={shareViaSMS}
                  onCopyWarranty={copyWarrantyLink}
              />
          ))}
          </ErrorBoundary>
        </main>
        <CompanyFooter logo={companyBranding.logo} />
    </div>
  );
}
