        const generateRegionalStats = (counts) => {
            return Object.entries(regions).map(([region, cities]) => {
                const cityData = cities.map(c => ({ name: c, count: counts[c] || 0 })).filter(c => c.count > 0).sort((a,b) => b.count - a.count);
                const total = cityData.reduce((sum, c) => sum + c.count, 0);
