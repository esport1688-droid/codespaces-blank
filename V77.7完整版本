                totalSalesRevenue += amount;
            } else {
                if (amount > 0) { salesStats[rawSalesName].potential += amount; totalPotentialRevenue += amount; }
            }
            if (isCompletedInstall) { totalDealPW += pwCount; }
            const isSurvey = service.includes("場勘"); 
            if (isSurvey) totalSurveyCount++;
            const isInstall = service.includes("安裝");
            const orderTechs = (order.technicians && order.technicians.length > 0) ? order.technicians : (order.technicianName ? [{name: order.technicianName}] : []);
            orderTechs.forEach(tech => {
