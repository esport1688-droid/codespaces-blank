            <div className="mb-6 flex justify-center">
                {companyBranding.logo ? (
                    <img src={companyBranding.logo} alt={COMPANY_NAME} className="h-24 object-contain mb-4" />
                ) : (
                    <div className="p-4 bg-blue-50 rounded-full"><Lock size={32} className="text-blue-600"/></div>
                )}
            </div>
            {!companyBranding.logo && <h1 className="text-2xl font-bold mb-2 text-gray-800">{COMPANY_NAME}</h1>}
            <p className="text-sm text-gray-500 mb-6">請輸入管理員通行碼以登入系統</p>
            <form onSubmit={handleLogin} className="space-y-4"><input type="password" value={passcode} onChange={(e) => setPasscode(e.target.value)} className="w-full text-center text-2xl font-bold tracking-widest p-3 border rounded-xl bg-gray-50 focus:ring-2 focus:ring-blue-500 outline-none" placeholder="••••" maxLength={4} inputMode="numeric" /><button type="submit" className="w-full bg-blue-600 text-white py-3 rounded-xl font-bold shadow-lg hover:bg-blue-700 flex items-center justify-center gap-2"><LogIn size={18}/> 登入系統</button></form><p className="mt-4 text-xs text-gray-300 font-mono">{SYSTEM_VERSION}</p>
        </div>
    </div>
  );

  // 3. System Settings
  if (view === 'system-settings') return (
    <div className="min-h-screen bg-gray-50 pb-20 font-sans text-gray-900">
        <DialogModal config={modalConfig} onClose={()=>setModalConfig(null)} />
        {showSuccess && <Toast message={toastMsg} onClose={()=>setShowSuccess(false)} />}
        <header className="bg-white px-6 py-5 shadow-sm flex justify-between items-center max-w-2xl mx-auto"><h1 className="text-xl font-bold flex gap-2"><Settings/>設定</h1><button onClick={()=>setView('list')}><X/></button></header>
        {showPermissionError && <PermissionErrorModal onClose={()=>setShowPermissionError(false)} />}
        <main className="p-4 space-y-6 max-w-2xl mx-auto">
            <div className="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                <div className="flex justify-between items-start mb-4">
                    <div>
                        <h3 className="text-lg font-bold text-gray-800 flex items-center gap-2"><ImageIcon className="text-purple-500"/> 品牌 Logo</h3>
                        <p className="text-sm text-gray-500 mt-1">上傳公司 Logo 以提升品牌辨識度 (建議透明背景 PNG)</p>
                    </div>
                </div>
                <div className="flex items-center gap-4">
                    <div className="w-20 h-20 bg-gray-50 rounded-xl border border-dashed border-gray-300 flex items-center justify-center overflow-hidden relative">
                         {companyBranding.logo ? (
                             <img src={companyBranding.logo} alt="Current Logo" className="w-full h-full object-contain p-2" />
                         ) : (
                             <span className="text-xs text-gray-400">無</span>
                         )}
                    </div>
                    <div className="flex-1">
                         <input type="file" accept="image/*" onChange={handleLogoUpload} className="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-purple-50 file:text-purple-700 hover:file:bg-purple-100"/>
                    </div>
                </div>
            </div>

            <div className="bg-white p-6 rounded-2xl shadow-sm border border-blue-100 relative overflow-hidden"><div className="absolute top-0 right-0 w-20 h-20 bg-blue-50 rounded-full -mr-10 -mt-10"></div><div className="relative z-10"><h3 className="text-lg font-bold text-gray-800 flex items-center gap-2"><Cloud className="text-blue-500"/> 連接私人資料庫</h3><p className="text-xs text-gray-500 mt-1 mb-4">輸入您自己的 Firebase Config JSON 以獲得完整權限與資料掌控權。</p>{isCustomDB ? (<div className="p-4 bg-green-50 border border-green-200 rounded-xl mb-4"><p className="text-green-700 text-sm font-bold flex items-center gap-2"><Shield size={16}/> 目前已連接私人資料庫 ({manualConfig.projectId})</p><button onClick={handleClearCustomConfig} className="mt-3 text-xs bg-white text-red-500 border border-red-200 px-3 py-1.5 rounded-lg font-bold hover:bg-red-50 transition">重置回預設資料庫</button></div>) : (<div className="space-y-3"><textarea className="w-full p-3 bg-gray-50 border rounded-xl text-xs font-mono h-32 focus:ring-2 focus:ring-blue-500 outline-none" placeholder='{"apiKey": "...", "authDomain": "...", ...}' value={customConfigInput} onChange={(e)=>setCustomConfigInput(e.target.value)} /><button onClick={handleSaveCustomConfig} className="w-full py-2 bg-blue-600 text-white rounded-xl font-bold text-sm hover:bg-blue-700">儲存並連接</button></div>)}</div></div>
            <div className="bg-white p-6 rounded-2xl shadow-sm border border-gray-100"><div className="flex justify-between items-start mb-4"><div><h3 className="text-lg font-bold text-gray-800 flex items-center gap-2"><Trophy className="text-yellow-500"/> Powerwall 實績</h3><p className="text-sm text-gray-500 mt-1">設定對外顯示的累積安裝數量</p></div></div><div className="space-y-4"><div><label className="block text-xs font-bold text-gray-600 mb-2">目前顯示總數</label><div className="flex items-center gap-2"><input type="number" className="flex-1 p-3 bg-gray-50 border border-gray-200 rounded-xl text-xl font-bold text-blue-600 outline-none focus:ring-2 focus:ring-blue-500" value={localPwCount} onChange={(e) => setLocalPwCount(e.target.value)} /><button onClick={saveCompanyStats} className="bg-blue-600 text-white font-bold py-3 px-4 rounded-xl hover:bg-blue-700 shadow-sm flex items-center gap-1 text-sm"><Save size={16}/> 儲存</button></div><p className="text-xs text-gray-400 mt-2 flex items-center gap-1"><Zap size={12}/> 系統自動統計數量：{stats.systemTotalPW} 顆</p></div></div></div>
            <div className="bg-white p-6 rounded-2xl shadow-sm border border-gray-100"><div className="flex justify-between items-start mb-4"><div><h3 className="text-lg font-bold text-gray-800 flex items-center gap-2"><Database className="text-gray-500"/> 資料保全</h3><p className="text-sm text-gray-500 mt-1">匯出目前檢視的資料</p></div></div><button onClick={handleExportData} className="w-full py-3 bg-gray-50 text-gray-700 border border-gray-200 rounded-xl font-bold flex items-center justify-center gap-2 hover:bg-gray-100 transition"><Download size={20} /> 匯出備份 (.json)</button><p className="text-xs text-gray-400 mt-2 text-center">建議定期備份，資料安全有保障。</p></div>
            <div className="bg-white p-6 rounded-2xl shadow-sm border space-y-4"><h3 className="font-bold text-gray-800">資料來源模式 (僅限預設庫)</h3><div className="flex items-center justify-between"><span className="text-sm text-gray-600">{useLegacyPath ? '⚠️ 舊版資料 (Legacy)' : '✅ 安全資料 (Artifacts)'}</span><button onClick={()=>setUseLegacyPath(!useLegacyPath)} className={`w-12 h-6 rounded-full p-1 transition ${useLegacyPath?'bg-red-500':'bg-green-500'}`}><div className={`w-4 h-4 bg-white rounded-full shadow-md transform transition ${useLegacyPath?'translate-x-6':''}`}></div></button></div><p className="text-xs text-gray-400">若使用預設資料庫且找不到舊資料，請切換此開關。</p></div>
        </main>
    </div>
  );
  
  // 4. Create / Edit Order
  if (view === 'create') return (
    <div className="min-h-screen bg-gray-50 pb-20 font-sans text-gray-900">
        <DialogModal config={modalConfig} onClose={()=>setModalConfig(null)} />
        {showSuccess && <Toast message={toastMsg} onClose={()=>setShowSuccess(false)} />}
        <header className="bg-white px-4 py-4 shadow-sm sticky top-0 flex items-center z-10 max-w-2xl mx-auto"><button onClick={() => setView('list')} className="p-2 -ml-2"><ChevronLeft size={24} /></button><h1 className="text-lg font-bold ml-2">{isEditing ? '修改工單' : '新增工單'}</h1></header>
        {showPermissionError && <PermissionErrorModal onClose={()=>setShowPermissionError(false)} />}
