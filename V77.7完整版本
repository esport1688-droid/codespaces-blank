                                  <div className="flex-1"> <p className="text-xs text-blue-400 font-bold mb-0.5">專屬業務顧問</p> <h3 className="text-base font-bold text-white">{selectedOrder.salesName}</h3> {salesTeam.find(s => s.name === selectedOrder.salesName)?.phone && ( <a href={`tel:${salesTeam.find(s => s.name === selectedOrder.salesName)?.phone}`} className="text-xs text-gray-500 flex items-center gap-1 mt-1 hover:text-white transition"> <Phone size={12} /> {salesTeam.find(s => s.name === selectedOrder.salesName)?.phone} </a> )} </div>
