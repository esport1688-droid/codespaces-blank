                              <div className="mb-8">
                                    <p className="text-xs text-gray-500 uppercase tracking-widest mb-3">已安裝設備</p>
                                    <div className="flex justify-center gap-2 flex-wrap items-end mb-3"> {Array.from({ length: selectedOrder.powerwallCount || 0 }).map((_, i) => ( <TeslaPowerwallGraphic key={`pw-${i}`} scale={0.5} /> ))} {Array.from({ length: selectedOrder.gatewayCount || 0 }).map((_, i) => ( <TeslaGatewayGraphic key={`gw-${i}`} scale={0.7} /> ))} </div>
                                    {(selectedOrder.powerwallCount > 0 || selectedOrder.gatewayCount > 0) && ( <div className="inline-flex items-center gap-3 text-xs font-bold text-gray-300 bg-gray-800/50 py-1.5 px-3 rounded-full border border-gray-700"> {selectedOrder.powerwallCount > 0 && ( <span>Powerwall x {selectedOrder.powerwallCount}</span> )} {selectedOrder.powerwallCount > 0 && selectedOrder.gatewayCount > 0 && ( <span className="text-gray-600">|</span> )} {selectedOrder.gatewayCount > 0 && ( <span>Gateway x {selectedOrder.gatewayCount}</span> )} </div> )}
