                <div className="flex gap-2">
                    <select className="w-1/3 p-3 bg-gray-50 border rounded-xl" value={formData.city} onChange={e=>setFormData(prev => ({...prev, city: e.target.value}))}>{TAIWAN_CITIES.map(c=><option key={c} value={c}>{c}</option>)}</select>
                    <input className="flex-1 p-3 bg-gray-50 border rounded-xl" value={formData.address} onChange={e=>setFormData(prev => ({...prev, address: e.target.value}))} placeholder="地址" />
                </div>
            </div>
            <div className="bg-white p-5 rounded-2xl shadow-sm border border-gray-100 space-y-4">
                <select className="w-full p-3 bg-gray-50 border rounded-xl" value={formData.serviceType} onChange={e=>setFormData(prev => ({...prev, serviceType: e.target.value}))}>{SERVICE_TYPES.map(t=><option key={t} value={t}>{t}</option>)}</select>
                <select className="w-full p-3 bg-gray-50 border rounded-xl" value={formData.status} onChange={e=>setFormData(prev => ({...prev, status: e.target.value}))}>{STATUS_OPTIONS.map(s=><option key={s} value={s}>{s}</option>)}</select>
                
                <div className="grid grid-cols-2 gap-4">
                    <div>
                        <label className="block text-xs font-bold text-gray-500 mb-1">業務人員 (可輸入/選擇)</label>
                        <input list="sales-list" className="w-full p-3 bg-gray-50 border rounded-xl" value={formData.salesName} onChange={e => setFormData(prev => ({...prev, salesName: e.target.value}))} placeholder="輸入或選擇..." />
                        <datalist id="sales-list">{salesTeam.map(s => <option key={s.id || s.name} value={s.name} />)}</datalist>
                    </div>
                    <div>
                        <label className="block text-xs font-bold text-gray-500 mb-1">KOL / 介紹人 (可輸入/選擇)</label>
                        <input list="kol-list" className="w-full p-3 bg-gray-50 border rounded-xl" value={formData.kolName} onChange={e => setFormData(prev => ({...prev, kolName: e.target.value}))} placeholder="輸入或選擇..." />
                        <datalist id="kol-list">{kols.map(k => <option key={k.id || k.name} value={k.name} />)}</datalist>
                    </div>
                </div>

                <div className="grid grid-cols-2 gap-4"><input type="date" className="w-full p-3 bg-gray-50 border rounded-xl" value={formData.date} onChange={e=>setFormData(prev => ({...prev, date: e.target.value}))} /><input type="time" className="w-full p-3 bg-gray-50 border rounded-xl" value={formData.time} onChange={e=>setFormData(prev => ({...prev, time: e.target.value}))} /></div>
                
                <div className="space-y-2">
                    <label className="text-xs font-bold text-gray-500">斷路器配置</label>
                    {formData.breakers.map((b, idx) => (
                        <div key={idx} className="flex gap-2">
                            <select className="flex-1 p-2 border rounded-lg" value={b.type} onChange={(e) => { const n = [...formData.breakers]; n[idx].type = e.target.value; setFormData(prev => ({...prev, breakers: n})); }}>{BREAKER_TYPES.map(t=><option key={t} value={t}>{t}</option>)}</select>
                            <input type="number" className="w-16 p-2 border rounded-lg text-center" value={b.count} onChange={(e) => { const n = [...formData.breakers]; n[idx].count = parseInt(e.target.value)||0; setFormData(prev => ({...prev, breakers: n})); }} />
                            <button type="button" onClick={()=>{ const n = formData.breakers.filter((_,i)=>i!==idx); setFormData(prev => ({...prev, breakers: n})); }} className="text-red-500"><Trash2/></button>
                        </div>
                    ))}
                    <button type="button" onClick={()=>setFormData(prev => ({...prev, breakers: [...prev.breakers, {type: BREAKER_TYPES[0], count: 1}]}))} className="w-full py-2 border-2 border-dashed border-gray-200 text-gray-400 rounded-lg flex justify-center items-center gap-1"><Plus size={16}/>新增斷路器</button>
                </div>

                <div><label className="text-xs font-bold text-gray-500">時間電價設定協助</label><select className="w-full p-3 mt-1 border rounded-xl" value={formData.touSetting} onChange={e=>setFormData(prev => ({...prev, touSetting: e.target.value}))}>{TOU_OPTIONS.map(o=><option key={o} value={o}>{o}</option>)}</select></div>
